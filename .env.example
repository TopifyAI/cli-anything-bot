# GitHub Bot Account Personal Access Token (classic)
# Required scopes: repo, notifications
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bot's GitHub username (e.g., cli-anything-bot)
BOT_USERNAME=cli-anything-bot

# Anthropic API Key for Claude
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude model to use (default: claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Polling interval in seconds (default: 30)
POLL_INTERVAL=30

# Working directory for cloned repos (default: /tmp/cli-anything-bot)
WORK_DIR=/tmp/cli-anything-bot

# Log level (default: INFO)
LOG_LEVEL=INFO
